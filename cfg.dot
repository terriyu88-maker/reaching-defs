digraph CFG {
  rankdir=TD;
  node [shape=record, fontname="Consolas", fontsize=11];
  edge [fontname="Consolas", fontsize=9];

  "B1" [label="{B1 | d1: %i1 = sub %m 1\ld2: %j1 = sub %n 0\ld3: %a1 = sub %u1 0\lbr label %B2}"];
  "B2" [label="{B2 | d4: %i2 = add %i1 1\ld5: %j2 = sub %j1 1\l%t1 = add %i2 %j2\l%cond = icmp %t1 10\lbr i1 %cond, label %B3, label %exit}"];
  "B3" [label="{B3 | d6: %a2 = sub %u2 0\l%t2 = add %i2 %a2\lbr label %B4}"];
  "B4" [label="{B4 | d7: %i3 = sub %u3 0\l%t3 = add %i3 %j2\lbr label %B2}"];
  "exit" [label="{exit | %t4 = add %i1 %i2\l%t5 = sub %t4 0\lret void\l}"];

  "B1" -> "B2";
  "B2" -> "B3";
  "B2" -> "exit";
  "B3" -> "B4";
  "B4" -> "B2";
}
